# ===== 交易機器人 API Keys =====
# 複製此檔為 .env 並填入您的 API Keys

# --- Alpaca (美股) ---
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets  # Paper Trading

# --- Shioaji (台股 - 永豐金) ---
SHIOAJI_API_KEY=your_shioaji_api_key
SHIOAJI_SECRET_KEY=your_shioaji_secret_key
SHIOAJI_SIMULATION=true  # true=模擬, false=實盤

# --- CCXT (加密幣) ---
CCXT_EXCHANGE=binance
CCXT_API_KEY=your_exchange_api_key
CCXT_SECRET_KEY=your_exchange_secret_key
CCXT_SANDBOX=true  # true=Testnet, false=實盤

# --- 通用設定 ---
TRADING_MODE=paper  # paper / live
LOG_LEVEL=INFO

# --- 監控與通知 (Monitoring & Notifications) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
USDT_TWD_RATE=31.4
